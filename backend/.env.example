PORT=3003
FRONTEND_URL=http://localhost:5173

# Logging: debug | info | warn | error (default: info). Use LOG_FORMAT=json for one JSON object per line.
# LOG_LEVEL=info
# LOG_FORMAT=text
# Set to true to log GET /health on every request (default: health requests are skipped).
# LOG_HTTP_HEALTH=false

# Clerk (backend — secret key only; publishable key lives in frontend/.env)
CLERK_SECRET_KEY=sk_test_...

# Neon Postgres (pooler URL from Neon dashboard)
DATABASE_URL=postgresql://neondb_owner:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
# PG_POOL_MAX=25
# AUTH_USER_CACHE_TTL_MS=60000

# AI SDK keys (at least one provider required for chat)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Email (optional — collaborator invite emails via SMTP, no custom domain required)
# Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
# SMTP_FROM_EMAIL=you@gmail.com
# SMTP_FROM_NAME=NextGen

# Figma MCP (optional — read-only design context import)
FIGMA_MCP_ENABLED=false
FIGMA_MCP_URL=https://mcp.figma.com/mcp
FIGMA_MCP_ACCESS_TOKEN=
FIGMA_MCP_HEADERS_JSON=
FIGMA_MCP_TIMEOUT_MS=45000

# Google Stitch MCP (optional — design context import)
STITCH_MCP_ENABLED=false
STITCH_MCP_URL=https://stitch.googleapis.com/mcp
STITCH_MCP_API_KEY=
STITCH_MCP_TIMEOUT_MS=45000

# Supabase OAuth (optional — enables "Connect with Supabase" one-click flow in the UI)
# Create an OAuth app at https://supabase.com/dashboard/org/_/integrations (OAuth Apps).
# Redirect URI must match SUPABASE_OAUTH_REDIRECT_URI (e.g. http://localhost:3003/api/supabase/oauth/callback).
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
SUPABASE_OAUTH_REDIRECT_URI=http://localhost:3003/api/supabase/oauth/callback

# Supabase MCP (optional — platform fallback when users connect via UI with their own PAT)
SUPABASE_MCP_ENABLED=false
SUPABASE_MCP_URL=https://mcp.supabase.com/mcp
SUPABASE_MCP_ACCESS_TOKEN=
SUPABASE_MCP_PROJECT_REF=
SUPABASE_MCP_FEATURES=database,docs,debugging
SUPABASE_MCP_TIMEOUT_MS=45000

# Upstash Redis (optional — blob cache, sandbox cache, MCP context cache)
# Do not wrap values in quotes.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Ops / tuning
SANDBOX_TOOLCHAIN_VERSION=webcontainer-npm-v1
DB_CONNECT_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=120000

# Backblaze B2 (optional — offloads sandbox snapshots and large code blobs)
# When unset, blobs stay in Postgres (dev-friendly fallback).
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=
B2_REGION=
B2_BLOB_INLINE_MAX_BYTES=65536
# Max parallel B2 fetches when materializing many blobs (default 10, max 32)
# BLOB_MATERIALIZE_CONCURRENCY=10
MAX_SNAPSHOT_BYTES=209715200
