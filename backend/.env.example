PORT=3001
FRONTEND_URL=http://localhost:5173

# Logging: debug | info | warn | error (default: info). Use LOG_FORMAT=json for one JSON object per line.
# LOG_LEVEL=info
# LOG_FORMAT=text
# Set to true to log GET /health on every request (default: health requests are skipped).
# LOG_HTTP_HEALTH=false

# Clerk
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres?sslmode=require
SUPABASE_STORAGE_BUCKET=code-files

# AI SDK Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Figma MCP (read-only design context import)
# Remote endpoint recommended by Figma. Enable only after your MCP auth/client access is configured.
FIGMA_MCP_ENABLED=false
FIGMA_MCP_URL=https://mcp.figma.com/mcp
# Optional bearer token or gateway token. Leave unset if your deployment injects auth via FIGMA_MCP_HEADERS_JSON.
FIGMA_MCP_ACCESS_TOKEN=
# Optional JSON object for additional MCP headers, e.g. {"X-Proxy-Auth":"..."}
FIGMA_MCP_HEADERS_JSON=
FIGMA_MCP_TIMEOUT_MS=45000
